#!/usr/bin/env zsh
set -euo pipefail

APP_NAME="claude-code-use-model"
SCRIPT_VERSION="0.1.1"

CONFIG_DIR="${CLAUDE_MIMO_CONFIG_DIR:-${XDG_CONFIG_HOME:-$HOME/.config}/${APP_NAME}}"
PROFILES_DIR="${CONFIG_DIR}/profiles"
KEYS_DIR="${CONFIG_DIR}/keys"
ACTIVE_PROFILE_FILE="${CONFIG_DIR}/active_profile"

DEFAULT_PROFILE="default"
DEFAULT_MODEL="mimo-v2.5-pro"
DEFAULT_FAST_MODEL="${DEFAULT_MODEL}"
DEFAULT_DISPLAY_NAME="Xiaomi MiMo V2.5 Pro"

MIMO_PAYG_BASE_URL="https://api.xiaomimimo.com/anthropic"
MIMO_TOKEN_PLAN_SGP_BASE_URL="https://token-plan-sgp.xiaomimimo.com/anthropic"
MIMO_TOKEN_PLAN_CN_BASE_URL="https://token-plan-cn.xiaomimimo.com/anthropic"
KEYCHAIN_SERVICE_PREFIX="${APP_NAME}"

die() {
  print -u2 -r -- "Error: $*"
  exit 1
}

say() {
  print -u2 -r -- "$*"
}

read_prompt() {
  local __var="$1"
  local __prompt="$2"
  print -u2 -n -- "${__prompt}"
  IFS= read -r "${__var}"
}

read_secret() {
  local __var="$1"
  local __prompt="$2"
  print -u2 -n -- "${__prompt}"
  IFS= read -rs "${__var}"
  print -u2 -r -- ""
}

ensure_dirs() {
  mkdir -p "${PROFILES_DIR}" "${KEYS_DIR}"
  chmod 700 "${CONFIG_DIR}" "${KEYS_DIR}" 2>/dev/null || true
}

valid_profile_name() {
  local name="$1"
  [[ -n "${name}" ]] || return 1
  [[ "${name}" != "." && "${name}" != ".." ]] || return 1
  [[ "${name}" =~ '^[A-Za-z0-9._-]+$' ]]
}

profile_file() {
  print -r -- "${PROFILES_DIR}/$1.env"
}

active_profile() {
  if [[ -s "${ACTIVE_PROFILE_FILE}" ]]; then
    local profile
    profile="$(<"${ACTIVE_PROFILE_FILE}")"
    if valid_profile_name "${profile}"; then
      print -r -- "${profile}"
      return
    fi
  fi
  print -r -- "${DEFAULT_PROFILE}"
}

set_active_profile() {
  local profile="$1"
  valid_profile_name "${profile}" || die "Invalid profile name '${profile}'. Use letters, numbers, dot, dash, or underscore."
  ensure_dirs
  print -r -- "${profile}" > "${ACTIVE_PROFILE_FILE}"
}

escape_double() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  value="${value//\$/\\\$}"
  value="${value//\`/\\\`}"
  print -r -- "${value}"
}

write_profile() {
  local profile="$1"
  local model="${2:-${DEFAULT_MODEL}}"
  local fast_model="${3:-${model}}"
  local base_url="${4:-}"
  local display_name="${5:-${DEFAULT_DISPLAY_NAME}}"
  local file

  valid_profile_name "${profile}" || die "Invalid profile name '${profile}'."
  validate_base_url "${base_url}"
  ensure_dirs
  file="$(profile_file "${profile}")"

  {
    print -r -- "# Generated by claude-mimo."
    print -r -- "# API keys are stored separately in macOS Keychain when available."
    print -r -- "MIMO_MODEL=\"$(escape_double "${model}")\""
    print -r -- "MIMO_FAST_MODEL=\"$(escape_double "${fast_model}")\""
    print -r -- "MIMO_BASE_URL=\"$(escape_double "${base_url}")\""
    print -r -- "MIMO_DISPLAY_NAME=\"$(escape_double "${display_name}")\""
  } > "${file}"
  chmod 600 "${file}" 2>/dev/null || true
}

init_profile() {
  local profile="$1"
  local file
  valid_profile_name "${profile}" || die "Invalid profile name '${profile}'."
  ensure_dirs
  file="$(profile_file "${profile}")"
  if [[ ! -f "${file}" ]]; then
    write_profile "${profile}" "${DEFAULT_MODEL}" "${DEFAULT_FAST_MODEL}" "" "${DEFAULT_DISPLAY_NAME}"
  fi
}

load_profile() {
  local profile="$1"
  local file
  local MIMO_MODEL="${DEFAULT_MODEL}"
  local MIMO_FAST_MODEL="${DEFAULT_FAST_MODEL}"
  local MIMO_BASE_URL=""
  local MIMO_DISPLAY_NAME="${DEFAULT_DISPLAY_NAME}"

  init_profile "${profile}"
  file="$(profile_file "${profile}")"
  # shellcheck disable=SC1090
  source "${file}"

  PROFILE_MODEL="${MIMO_MODEL:-${DEFAULT_MODEL}}"
  PROFILE_FAST_MODEL="${MIMO_FAST_MODEL:-${PROFILE_MODEL}}"
  PROFILE_BASE_URL="${MIMO_BASE_URL:-}"
  PROFILE_DISPLAY_NAME="${MIMO_DISPLAY_NAME:-${DEFAULT_DISPLAY_NAME}}"
}

profile_names() {
  ensure_dirs
  local file
  local found=0
  for file in "${PROFILES_DIR}"/*.env(N); do
    print -r -- "${${file:t}:r}"
    found=1
  done
  if (( ! found )); then
    print -r -- "${DEFAULT_PROFILE}"
  fi
}

keychain_service() {
  print -r -- "${KEYCHAIN_SERVICE_PREFIX}:$1:api-key"
}

key_file() {
  print -r -- "${KEYS_DIR}/$1.key"
}

get_stored_key() {
  local profile="$1"
  local service
  local file
  local value=""

  service="$(keychain_service "${profile}")"
  if [[ "${CLAUDE_MIMO_KEY_STORAGE:-keychain}" != "file" ]] && command -v security >/dev/null 2>&1; then
    value="$(security find-generic-password -a "${USER:-$(whoami)}" -s "${service}" -w 2>/dev/null || true)"
    if [[ -n "${value}" ]]; then
      print -r -- "${value}"
      return
    fi

    if [[ "${profile}" == "${DEFAULT_PROFILE}" ]]; then
      value="$(security find-generic-password -a "${USER:-$(whoami)}" -s mimo-api-key -w 2>/dev/null || true)"
      if [[ -n "${value}" ]]; then
        print -r -- "${value}"
        return
      fi
    fi
  fi

  file="$(key_file "${profile}")"
  if [[ -f "${file}" ]]; then
    <"${file}"
  fi
}

set_stored_key() {
  local profile="$1"
  local api_key="$2"
  local service
  local file

  [[ -n "${api_key}" ]] || die "API key cannot be empty."
  ensure_dirs
  service="$(keychain_service "${profile}")"

  if [[ "${CLAUDE_MIMO_KEY_STORAGE:-keychain}" != "file" ]] && command -v security >/dev/null 2>&1; then
    if security add-generic-password -a "${USER:-$(whoami)}" -s "${service}" -w "${api_key}" -U >/dev/null 2>&1; then
      print -r -- "Saved API key in macOS Keychain for profile '${profile}'."
      return
    fi
    print -u2 -r -- "Warning: Keychain save failed. Falling back to a local key file."
  fi

  file="$(key_file "${profile}")"
  umask 077
  print -r -- "${api_key}" > "${file}"
  chmod 600 "${file}" 2>/dev/null || true
  print -r -- "Saved API key in ${file}."
}

delete_stored_key() {
  local profile="$1"
  local service
  service="$(keychain_service "${profile}")"

  if command -v security >/dev/null 2>&1; then
    security delete-generic-password -a "${USER:-$(whoami)}" -s "${service}" >/dev/null 2>&1 || true
  fi
  rm -f "$(key_file "${profile}")"
}

mask_key() {
  local key="$1"
  local len="${#key}"
  if [[ -z "${key}" ]]; then
    print -r -- "(not set)"
  elif (( len <= 8 )); then
    print -r -- "********"
  else
    print -r -- "${key[1,4]}...${key[-4,-1]}"
  fi
}

resolve_base_url() {
  local configured="$1"
  local api_key="$2"

  if [[ -n "${configured}" ]]; then
    print -r -- "${configured}"
  elif [[ "${api_key}" == sk-* ]]; then
    print -r -- "${MIMO_PAYG_BASE_URL}"
  else
    print -r -- "${MIMO_TOKEN_PLAN_SGP_BASE_URL}"
  fi
}

validate_base_url() {
  local url="${1:-}"
  [[ -z "${url}" ]] && return

  if [[ "${url}" == *$'\n'* || "${url}" == *$'\r'* ]]; then
    die "Base URL contains line breaks. Run 'claude-mimo config' and choose a clean Base URL."
  fi

  if [[ ! "${url}" =~ '^https?://[^[:space:]]+$' ]]; then
    die "Invalid Base URL '${url}'. It must be a single http(s) URL."
  fi
}

find_claude_bin() {
  if [[ -n "${CLAUDE_BIN:-}" ]]; then
    [[ -x "${CLAUDE_BIN}" ]] || die "CLAUDE_BIN is set but not executable: ${CLAUDE_BIN}"
    print -r -- "${CLAUDE_BIN}"
    return
  fi

  local found=""
  if found="$(command -v claude 2>/dev/null)"; then
    print -r -- "${found}"
    return
  fi

  if [[ -x "${HOME}/.local/bin/claude" ]]; then
    print -r -- "${HOME}/.local/bin/claude"
    return
  fi

  die "Cannot find the 'claude' command. Install Claude Code first, or set CLAUDE_BIN=/path/to/claude."
}

show_usage() {
  cat <<EOF
claude-mimo ${SCRIPT_VERSION}

Usage:
  claude-mimo                  Start Claude Code with the active MiMo profile
  claude-mimo config           Open interactive configuration
  claude-mimo status           Show active profile, model, base URL, and key status
  claude-mimo profiles         List profiles
  claude-mimo use <profile>    Switch active profile
  claude-mimo help             Show this help

Non-interactive config:
  claude-mimo config --profile work --model mimo-v2.5-pro
  claude-mimo config --profile work --api-key 'YOUR_KEY'
  claude-mimo config --profile work --base-url '${MIMO_TOKEN_PLAN_SGP_BASE_URL}'
  claude-mimo config --profile work --auto-base-url

Environment overrides:
  MIMO_API_KEY, MIMO_MODEL, MIMO_FAST_MODEL, MIMO_BASE_URL, CLAUDE_BIN
EOF
}

show_status() {
  local profile
  local key
  local model
  local fast_model
  local configured_base
  local base_url
  local key_source="profile store"

  profile="$(active_profile)"
  load_profile "${profile}"

  if [[ -n "${MIMO_API_KEY:-}" ]]; then
    key="${MIMO_API_KEY}"
    key_source="MIMO_API_KEY environment variable"
  else
    key="$(get_stored_key "${profile}")"
  fi

  model="${MIMO_MODEL:-${PROFILE_MODEL}}"
  fast_model="${MIMO_FAST_MODEL:-${PROFILE_FAST_MODEL}}"
  configured_base="${MIMO_BASE_URL:-${PROFILE_BASE_URL}}"
  base_url="$(resolve_base_url "${configured_base}" "${key}")"

  print -r -- "Profile:      ${profile}"
  print -r -- "Model:        ${model}"
  print -r -- "Fast model:   ${fast_model}"
  if [[ -n "${configured_base}" ]]; then
    print -r -- "Base URL:     ${base_url}"
  else
    print -r -- "Base URL:     ${base_url} (auto)"
  fi
  print -r -- "API key:      $(mask_key "${key}")"
  print -r -- "Key source:   ${key_source}"
  print -r -- "Config dir:   ${CONFIG_DIR}"
}

list_profiles() {
  local active
  local name
  active="$(active_profile)"
  for name in ${(f)"$(profile_names)"}; do
    if [[ "${name}" == "${active}" ]]; then
      print -r -- "* ${name}"
    else
      print -r -- "  ${name}"
    fi
  done
}

switch_profile() {
  local profile="$1"
  valid_profile_name "${profile}" || die "Invalid profile name '${profile}'. Use letters, numbers, dot, dash, or underscore."
  init_profile "${profile}"
  set_active_profile "${profile}"
  print -r -- "Active profile: ${profile}"
}

prompt_model() {
  local current="$1"
  local choice
  local custom

  say ""
  say "Choose model:"
  say "  1) mimo-v2.5-pro"
  say "  2) Custom model id"
  read_prompt choice "Model [current: ${current}] > "

  case "${choice}" in
    "" )
      print -r -- "${current}"
      ;;
    1 )
      print -r -- "mimo-v2.5-pro"
      ;;
    2 )
      read_prompt custom "Model id > "
      [[ -n "${custom}" ]] || die "Model id cannot be empty."
      print -r -- "${custom}"
      ;;
    * )
      print -r -- "${choice}"
      ;;
  esac
}

prompt_base_url() {
  local current="$1"
  local choice
  local custom

  say ""
  say "Choose Base URL:"
  say "  1) Auto by API key"
  say "  2) Pay-as-you-go (${MIMO_PAYG_BASE_URL})"
  say "  3) Token plan Singapore (${MIMO_TOKEN_PLAN_SGP_BASE_URL})"
  say "  4) Token plan China (${MIMO_TOKEN_PLAN_CN_BASE_URL})"
  say "  5) Custom Base URL"
  if [[ -n "${current}" ]]; then
    read_prompt choice "Base URL [current: ${current}] > "
  else
    read_prompt choice "Base URL [current: auto] > "
  fi

  case "${choice}" in
    "" )
      print -r -- "${current}"
      ;;
    1 )
      print -r -- ""
      ;;
    2 )
      print -r -- "${MIMO_PAYG_BASE_URL}"
      ;;
    3 )
      print -r -- "${MIMO_TOKEN_PLAN_SGP_BASE_URL}"
      ;;
    4 )
      print -r -- "${MIMO_TOKEN_PLAN_CN_BASE_URL}"
      ;;
    5 )
      read_prompt custom "Base URL > "
      [[ -n "${custom}" ]] || die "Base URL cannot be empty."
      validate_base_url "${custom}"
      print -r -- "${custom}"
      ;;
    * )
      validate_base_url "${choice}"
      print -r -- "${choice}"
      ;;
  esac
}

interactive_switch_profile() {
  local current="$1"
  local names
  local choice
  local selected=""
  local i=1

  names=(${(f)"$(profile_names)"})

  print -r -- ""
  print -r -- "Profiles:"
  for name in "${names[@]}"; do
    if [[ "${name}" == "${current}" ]]; then
      print -r -- "  ${i}) ${name} *"
    else
      print -r -- "  ${i}) ${name}"
    fi
    (( i++ ))
  done
  print -r -- ""
  read_prompt choice "Profile number or new profile name > "
  [[ -n "${choice}" ]] || return

  if [[ "${choice}" =~ '^[0-9]+$' ]] && (( choice >= 1 && choice <= ${#names[@]} )); then
    selected="${names[choice]}"
  else
    selected="${choice}"
  fi

  valid_profile_name "${selected}" || die "Invalid profile name '${selected}'. Use letters, numbers, dot, dash, or underscore."
  switch_profile "${selected}"
}

interactive_config() {
  local profile
  local key
  local masked
  local base_url
  local choice
  local new_value

  ensure_dirs
  profile="$(active_profile)"
  init_profile "${profile}"

  while true; do
    load_profile "${profile}"
    key="$(get_stored_key "${profile}")"
    masked="$(mask_key "${key}")"
    base_url="$(resolve_base_url "${PROFILE_BASE_URL}" "${key}")"

    print -r -- ""
    print -r -- "claude-mimo config"
    print -r -- "Profile:    ${profile}"
    print -r -- "Model:      ${PROFILE_MODEL}"
    print -r -- "Fast model: ${PROFILE_FAST_MODEL}"
    if [[ -n "${PROFILE_BASE_URL}" ]]; then
      print -r -- "Base URL:   ${base_url}"
    else
      print -r -- "Base URL:   ${base_url} (auto)"
    fi
    print -r -- "API key:    ${masked}"
    print -r -- ""
    print -r -- "  1) Switch/create profile"
    print -r -- "  2) Set/change API key"
    print -r -- "  3) Select model"
    print -r -- "  4) Select fast model"
    print -r -- "  5) Select Base URL"
    print -r -- "  6) Delete API key for this profile"
    print -r -- "  7) Show status"
    print -r -- "  0) Exit"
    read_prompt choice "> "

    case "${choice}" in
      1 )
        interactive_switch_profile "${profile}"
        profile="$(active_profile)"
        ;;
      2 )
        print -r -- "Paste API key for profile '${profile}' (input hidden)."
        read_secret new_value "API key > "
        [[ -n "${new_value}" ]] || die "API key cannot be empty."
        set_stored_key "${profile}" "${new_value}"
        ;;
      3 )
        new_value="$(prompt_model "${PROFILE_MODEL}")"
        write_profile "${profile}" "${new_value}" "${PROFILE_FAST_MODEL}" "${PROFILE_BASE_URL}" "Xiaomi MiMo (${new_value})"
        ;;
      4 )
        new_value="$(prompt_model "${PROFILE_FAST_MODEL}")"
        write_profile "${profile}" "${PROFILE_MODEL}" "${new_value}" "${PROFILE_BASE_URL}" "${PROFILE_DISPLAY_NAME}"
        ;;
      5 )
        new_value="$(prompt_base_url "${PROFILE_BASE_URL}")"
        write_profile "${profile}" "${PROFILE_MODEL}" "${PROFILE_FAST_MODEL}" "${new_value}" "${PROFILE_DISPLAY_NAME}"
        ;;
      6 )
        delete_stored_key "${profile}"
        print -r -- "Deleted API key for profile '${profile}'."
        ;;
      7 )
        show_status
        ;;
      0 | q | quit | exit )
        print -r -- "Done."
        return
        ;;
      * )
        print -r -- "Unknown option: ${choice}"
        ;;
    esac
  done
}

config_non_interactive() {
  local profile
  local model
  local fast_model
  local base_url
  local display_name
  local api_key=""

  profile="$(active_profile)"
  init_profile "${profile}"
  load_profile "${profile}"
  model="${PROFILE_MODEL}"
  fast_model="${PROFILE_FAST_MODEL}"
  base_url="${PROFILE_BASE_URL}"
  display_name="${PROFILE_DISPLAY_NAME}"

  while (( $# > 0 )); do
    case "$1" in
      --profile )
        [[ $# -ge 2 ]] || die "--profile requires a value."
        profile="$2"
        valid_profile_name "${profile}" || die "Invalid profile name '${profile}'."
        init_profile "${profile}"
        load_profile "${profile}"
        model="${PROFILE_MODEL}"
        fast_model="${PROFILE_FAST_MODEL}"
        base_url="${PROFILE_BASE_URL}"
        display_name="${PROFILE_DISPLAY_NAME}"
        shift 2
        ;;
      --api-key )
        [[ $# -ge 2 ]] || die "--api-key requires a value."
        api_key="$2"
        shift 2
        ;;
      --api-key-stdin )
        api_key="$(cat)"
        shift
        ;;
      --model )
        [[ $# -ge 2 ]] || die "--model requires a value."
        model="$2"
        display_name="Xiaomi MiMo (${model})"
        shift 2
        ;;
      --fast-model )
        [[ $# -ge 2 ]] || die "--fast-model requires a value."
        fast_model="$2"
        shift 2
        ;;
      --base-url )
        [[ $# -ge 2 ]] || die "--base-url requires a value."
        base_url="$2"
        shift 2
        ;;
      --auto-base-url )
        base_url=""
        shift
        ;;
      --display-name )
        [[ $# -ge 2 ]] || die "--display-name requires a value."
        display_name="$2"
        shift 2
        ;;
      -h | --help )
        show_usage
        return
        ;;
      * )
        die "Unknown config option: $1"
        ;;
    esac
  done

  write_profile "${profile}" "${model}" "${fast_model}" "${base_url}" "${display_name}"
  set_active_profile "${profile}"
  if [[ -n "${api_key}" ]]; then
    set_stored_key "${profile}" "${api_key}"
  fi
  show_status
}

run_claude() {
  local profile
  local api_key
  local model
  local fast_model
  local configured_base
  local base_url
  local display_name
  local claude_bin

  profile="$(active_profile)"
  load_profile "${profile}"

  api_key="${MIMO_API_KEY:-}"
  if [[ -z "${api_key}" ]]; then
    api_key="$(get_stored_key "${profile}")"
  fi

  if [[ -z "${api_key}" ]]; then
    cat >&2 <<EOF
Missing MiMo API key for profile '${profile}'.

Run:
  claude-mimo config

Or set it directly:
  claude-mimo config --profile ${profile} --api-key 'YOUR_MIMO_API_KEY'
EOF
    exit 2
  fi

  model="${MIMO_MODEL:-${PROFILE_MODEL}}"
  fast_model="${MIMO_FAST_MODEL:-${PROFILE_FAST_MODEL}}"
  configured_base="${MIMO_BASE_URL:-${PROFILE_BASE_URL}}"
  base_url="$(resolve_base_url "${configured_base}" "${api_key}")"
  validate_base_url "${base_url}"
  display_name="${PROFILE_DISPLAY_NAME}"
  claude_bin="$(find_claude_bin)"

  export ANTHROPIC_BASE_URL="${base_url}"
  export ANTHROPIC_AUTH_TOKEN="${api_key}"
  unset ANTHROPIC_API_KEY

  export ANTHROPIC_MODEL="${model}"
  export ANTHROPIC_CUSTOM_MODEL_OPTION="${model}"
  export ANTHROPIC_CUSTOM_MODEL_OPTION_NAME="${display_name}"
  export ANTHROPIC_CUSTOM_MODEL_OPTION_DESCRIPTION="${display_name} through Anthropic-compatible API"

  export ANTHROPIC_DEFAULT_SONNET_MODEL="${model}"
  export ANTHROPIC_DEFAULT_OPUS_MODEL="${model}"
  export ANTHROPIC_DEFAULT_HAIKU_MODEL="${fast_model}"
  export ANTHROPIC_SMALL_FAST_MODEL="${fast_model}"
  export ANTHROPIC_DEFAULT_SONNET_MODEL_NAME="${display_name}"
  export ANTHROPIC_DEFAULT_OPUS_MODEL_NAME="${display_name}"
  export ANTHROPIC_DEFAULT_HAIKU_MODEL_NAME="${display_name}"

  if [[ -n "${ANTHROPIC_CUSTOM_HEADERS:-}" ]]; then
    export ANTHROPIC_CUSTOM_HEADERS="${ANTHROPIC_CUSTOM_HEADERS}
api-key: ${api_key}"
  else
    export ANTHROPIC_CUSTOM_HEADERS="api-key: ${api_key}"
  fi

  export CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS="${CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS:-1}"
  export DISABLE_INTERLEAVED_THINKING="${DISABLE_INTERLEAVED_THINKING:-1}"
  export CLAUDE_CODE_DISABLE_THINKING="${CLAUDE_CODE_DISABLE_THINKING:-1}"

  if [[ "${MIMO_DISABLE_PROMPT_CACHING:-0}" == "1" ]]; then
    export DISABLE_PROMPT_CACHING=1
  else
    unset DISABLE_PROMPT_CACHING
  fi

  exec "${claude_bin}" "$@"
}

main() {
  local command="${1:-}"

  case "${command}" in
    "" )
      run_claude
      ;;
    config )
      shift
      if (( $# == 0 )); then
        interactive_config
      else
        config_non_interactive "$@"
      fi
      ;;
    status )
      show_status
      ;;
    profiles )
      list_profiles
      ;;
    use )
      shift
      [[ $# -ge 1 ]] || die "Usage: claude-mimo use <profile>"
      switch_profile "$1"
      ;;
    help | -h | --help )
      show_usage
      ;;
    version | -v | --version )
      print -r -- "claude-mimo ${SCRIPT_VERSION}"
      ;;
    * )
      run_claude "$@"
      ;;
  esac
}

main "$@"
